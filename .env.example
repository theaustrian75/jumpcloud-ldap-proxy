# Copy to .env next to docker-compose.yml and fill in.
# Immutable release tag or manifest digest; do not use :latest in production.
LDAP_PROXY_IMAGE=ghcr.io/theaustrian75/jumpcloud-ldap-proxy@sha256:REPLACE_WITH_MANIFEST_DIGEST
# Numeric container identity and tmpfs ownership. QNAP defaults:
# httpdusr=99, everyone=100.
LDAP_PROXY_UID=99
LDAP_PROXY_GID=100
# JumpCloud org ID (JumpCloud console -> LDAP; the o=<id> in your base DN)
JC_ORG_ID=changeme
# UID of the JumpCloud account configured as QTS's LDAP bind user.
# Only this identity may read cached password/hash attributes.
JC_CACHE_READER_UID=changeme
# Accepted values:
#   stats (default) = connections, operations, filters, and results
#   none            = only unavoidable/high-priority messages
# Any other value is rejected at startup.
SLAPD_LOGLEVEL=stats
# Optional: only if a client on ANOTHER host must reach this proxy.
# Single IPv4 or OpenLDAP ip%netmask form (e.g. 192.168.1.0%255.255.255.0).
# Leave unset for the QNAP-local deployment.
#ALLOWED_CLIENT_IP=192.168.1.50
